// Native Web Component - No Hardcoded CSS Blobs
class UIContainer extends HTMLElement {
  constructor() {
    super();
    this.attachShadow({ mode: 'open' });
  }

  static get observedAttributes() { return ['state']; }

  // Injecting styles via a linked stylesheet or constructable stylesheet
  connectedCallback() {
    this.render();
  }

  render() {
    this.shadowRoot.innerHTML = `
      <!-- Link global styles to Shadow DOM -->
      <link rel="stylesheet" href="/assets/css/tailwind.min.css">
      
      <div class="p-4 border border-gray-200 rounded-md shadow-sm bg-white">
        <!-- Loading State -->
        <div id="loading" class="animate-pulse space-y-2" hidden>
          <div class="h-4 bg-gray-200 rounded w-3/4"></div>
        </div>

        <!-- Content Slot -->
        <div id="content" class="text-gray-900">
          <slot></slot>
        </div>

        <!-- Error State -->
        <div id="error" class="text-red-600 font-semibold" hidden>
          Unable to render component.
        </div>
      </div>
    `;
  }

  attributeChangedCallback(name, oldValue, newValue) {
    if (oldValue !== newValue) {
      const states = ['loading', 'content', 'error'];
      states.forEach(state => {
        const el = this.shadowRoot.getElementById(state);
        if (el) el.hidden = (newValue !== state);
      });
    }
  }
}

customElements.define('ui-container', UIContainer);

